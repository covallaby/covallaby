{
  "name": "@covallaby/server",
  "version": "0.1.0",
  "description": "Self-hosted Covallaby: coverage history, dashboards, and live badges from one tiny process.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "dev:web": "vite",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text-summary --coverage.include='src/**' --coverage.exclude='src/vendor/**'",
    "build:demo": "vite build -c vite.demo.config.ts",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "@hono/node-server": "^1.13.8",
    "fast-xml-parser": "^4.5.1",
    "hono": "^4.6.20",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^22",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "storybook": "^10.5.0",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  },
  "author": "Josh Holtz <me@joshholtz.com> (https://mostlygood.dev)",
  "homepage": "https://covallaby.com"
}
