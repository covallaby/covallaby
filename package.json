{
  "name": "@covallaby/server",
  "version": "0.1.0",
  "description": "Self-hosted Covallaby: coverage history, dashboards, and live badges from one tiny process.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "dev:web": "vite"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "fast-xml-parser": "^4.5.1",
    "hono": "^4.6.20",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "@tailwindcss/vite": "^4.0.6",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "tailwindcss": "^4.0.6",
    "vite": "^6.1.0"
  }
}
