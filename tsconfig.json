{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "rootDir": "src",
    "outDir": "dist",
    "allowImportingTsExtensions": false
  },
  "include": ["src"]
}
